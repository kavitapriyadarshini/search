# Apify — https://console.apify.com/account/integrations
APIFY_API_KEY=apify_api_xxxxxxxx

# Optional: override default actors (use ~ in ID)
# APIFY_LINKEDIN_ACTOR_ID=curious_coder~linkedin-jobs-scraper
# APIFY_NAUKRI_ACTOR_ID=memo23~naukri-scraper

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Notion — https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required on Vercel — Vercel Cron sends Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret-here
